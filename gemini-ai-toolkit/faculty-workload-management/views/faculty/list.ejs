<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="content p-3 p-lg-4">
    <div class="d-flex flex-wrap align-items-end justify-content-between gap-2 mb-3">
      <div>
        <div class="text-muted small">Admin</div>
        <h1 class="h4 mb-0">Faculty Management</h1>
      </div>
      <a class="btn btn-dark" href="/faculty/new">Add Faculty</a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <form class="row g-2 align-items-end" method="get" action="/faculty">
          <div class="col-12 col-md-10">
            <label class="form-label">Search</label>
            <input name="q" class="form-control" value="<%= q %>" placeholder="Name, email, department" />
          </div>
          <div class="col-12 col-md-2 d-grid">
            <button class="btn btn-outline-dark" type="submit">Search</button>
          </div>
        </form>
      </div>

      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Department</th>
              <th class="text-end">Total Workload (hrs)</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!rows.length) { %>
              <tr>
                <td colspan="5" class="text-center text-muted py-4">No faculty found.</td>
              </tr>
            <% } %>
            <% rows.forEach(f => { %>
              <tr>
                <td class="fw-semibold"><%= f.name %></td>
                <td><%= f.email %></td>
                <td><%= f.department %></td>
                <td class="text-end"><%= f.totalHours %></td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-dark" href="/faculty/<%= f._id %>/edit">Edit</a>
                  <form action="/faculty/<%= f._id %>?_method=DELETE" method="post" class="d-inline" data-confirm="Delete this faculty (and all their workloads)?">
                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
