<%- include('../partials/head') %>
<body class="app-body">
<%- include('../partials/sidebar') %>
<div class="main-content" id="mainContent">
  <%- include('../partials/navbar') %>
  <div class="page-content">
    <%- include('../partials/flash') %>

    <div class="table-card">
      <div class="table-header">
        <h3><i class="fas fa-users"></i> All Users (<%= users.length %>)</h3>
      </div>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Papers Uploaded</th>
              <th>Last Login</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((user, idx) => { %>
            <tr>
              <td><%= idx + 1 %></td>
              <td>
                <div class="user-cell">
                  <div class="avatar-sm"><%= user.name[0].toUpperCase() %></div>
                  <%= user.name %>
                </div>
              </td>
              <td><%= user.email %></td>
              <td>
                <span class="badge-<%= user.role %>"><%= user.role %></span>
              </td>
              <td><%= user.papersUploaded || 0 %></td>
              <td><%= user.lastLogin ? new Date(user.lastLogin).toLocaleDateString('en-IN') : 'Never' %></td>
              <td><%= new Date(user.createdAt).toLocaleDateString('en-IN') %></td>
              <td class="action-btns">
                <% if (user._id.toString() !== session.userId) { %>
                  <form action="/users/<%= user._id %>/role?_method=PUT" method="POST" style="display:inline" class="role-form">
                    <select name="role" class="role-select" onchange="this.form.submit()">
                      <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
                      <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                  </form>
                  <form action="/users/<%= user._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete user <%= user.name %>? This will also delete all their papers.')">
                    <button type="submit" class="btn btn-sm btn-danger" title="Delete User"><i class="fas fa-trash"></i></button>
                  </form>
                <% } else { %>
                  <span class="text-muted">You</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
