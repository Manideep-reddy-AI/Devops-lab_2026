<%- include('../partials/head') %>
<body class="app-body">
<%- include('../partials/sidebar') %>
<div class="main-content" id="mainContent">
  <%- include('../partials/navbar') %>
  <div class="page-content">
    <%- include('../partials/flash') %>

    <div class="page-toolbar">
      <form action="/papers" method="GET" class="search-form">
        <div class="search-group">
          <i class="fas fa-search"></i>
          <input type="text" name="search" value="<%= search %>" placeholder="Search by title, author, or abstract...">
        </div>
        <select name="category">
          <option value="all" <%= selectedCategory === 'all' ? 'selected' : '' %>>All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= selectedCategory === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
        <select name="sort">
          <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest First</option>
          <option value="title" <%= sort === 'title' ? 'selected' : '' %>>Title A-Z</option>
          <option value="author" <%= sort === 'author' ? 'selected' : '' %>>Author A-Z</option>
          <option value="year" <%= sort === 'year' ? 'selected' : '' %>>Year (Latest)</option>
        </select>
        <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filter</button>
        <a href="/papers" class="btn btn-outline">Clear</a>
      </form>
      <a href="/papers/create" class="btn btn-success"><i class="fas fa-upload"></i> Upload Paper</a>
    </div>

    <div class="table-card">
      <div class="table-header">
        <h3><i class="fas fa-file-pdf"></i> Research Papers (<%= papers.length %>)</h3>
      </div>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Title</th>
              <th>Author</th>
              <th>Category</th>
              <th>Year</th>
              <th>Uploaded By</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (papers.length === 0) { %>
              <tr><td colspan="8" class="no-data"><i class="fas fa-inbox"></i> No papers found.</td></tr>
            <% } else { %>
              <% papers.forEach((paper, idx) => { %>
              <tr>
                <td><%= idx + 1 %></td>
                <td class="paper-title-cell">
                  <a href="/papers/<%= paper._id %>"><%= paper.title.length > 55 ? paper.title.substring(0,55)+'...' : paper.title %></a>
                </td>
                <td><%= paper.author %></td>
                <td><span class="category-badge"><%= paper.category %></span></td>
                <td><%= paper.year %></td>
                <td><%= paper.uploadedBy ? paper.uploadedBy.name : 'N/A' %></td>
                <td><%= new Date(paper.createdAt).toLocaleDateString('en-IN') %></td>
                <td class="action-btns">
                  <a href="/papers/<%= paper._id %>" class="btn btn-sm btn-primary" title="View"><i class="fas fa-eye"></i></a>
                  <% if (session && (session.role === 'admin' || (paper.uploadedBy && paper.uploadedBy._id && paper.uploadedBy._id.toString() === session.userId))) { %>
                  <a href="/papers/<%= paper._id %>/edit" class="btn btn-sm btn-warning" title="Edit"><i class="fas fa-edit"></i></a>
                  <form action="/papers/<%= paper._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this paper permanently?')">
                    <button type="submit" class="btn btn-sm btn-danger" title="Delete"><i class="fas fa-trash"></i></button>
                  </form>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
