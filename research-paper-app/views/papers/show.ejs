<%- include('../partials/head') %>
<body class="app-body">
<%- include('../partials/sidebar') %>
<div class="main-content" id="mainContent">
  <%- include('../partials/navbar') %>
  <div class="page-content">
    <%- include('../partials/flash') %>

    <div class="paper-detail-card">
      <div class="paper-detail-header">
        <div class="paper-meta-top">
          <span class="category-badge large"><%= paper.category %></span>
          <span class="year-badge"><i class="fas fa-calendar"></i> <%= paper.year %></span>
        </div>
        <h1 class="paper-title-large"><%= paper.title %></h1>
        <div class="paper-authors">
          <i class="fas fa-users"></i> <strong>Authors:</strong> <%= paper.author %>
        </div>
        <div class="paper-uploader">
          <i class="fas fa-user-upload"></i>
          Uploaded by <strong><%= paper.uploadedBy ? paper.uploadedBy.name : 'Unknown' %></strong>
          on <%= new Date(paper.createdAt).toLocaleDateString('en-IN', {day:'numeric', month:'long', year:'numeric'}) %>
        </div>
        <div class="paper-actions-row">
          <a href="/uploads/pdfs/<%= paper.pdfFile %>" target="_blank" class="btn btn-primary">
            <i class="fas fa-external-link-alt"></i> Open PDF
          </a>
          <a href="/uploads/pdfs/<%= paper.pdfFile %>" download class="btn btn-success">
            <i class="fas fa-download"></i> Download PDF
          </a>
          <% if (session && (session.role === 'admin' || (paper.uploadedBy && paper.uploadedBy._id && paper.uploadedBy._id.toString() === session.userId))) { %>
          <a href="/papers/<%= paper._id %>/edit" class="btn btn-warning">
            <i class="fas fa-edit"></i> Edit
          </a>
          <form action="/papers/<%= paper._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this paper permanently?')">
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
          </form>
          <% } %>
          <a href="/papers" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
        </div>
      </div>

      <div class="paper-body">
        <section class="abstract-section">
          <h2><i class="fas fa-align-left"></i> Abstract</h2>
          <p class="abstract-text"><%= paper.abstract %></p>
        </section>

        <section class="pdf-preview-section">
          <h2><i class="fas fa-file-pdf"></i> PDF Preview</h2>
          <div class="pdf-embed-wrapper">
            <iframe
              src="/uploads/pdfs/<%= paper.pdfFile %>"
              class="pdf-embed"
              title="<%= paper.title %>"
              allowfullscreen>
              <p>Your browser does not support iframes.
                <a href="/uploads/pdfs/<%= paper.pdfFile %>">Download the PDF</a> to view it.
              </p>
            </iframe>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
