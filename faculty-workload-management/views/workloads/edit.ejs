<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="content p-3 p-lg-4">
    <div class="d-flex align-items-end justify-content-between gap-2 mb-3">
      <div>
        <div class="text-muted small">Update</div>
        <h1 class="h4 mb-0">Edit Workload</h1>
      </div>
      <a class="btn btn-outline-dark" href="/workloads">Back</a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <form action="/workloads/<%= wl._id %>?_method=PUT" method="post">
          <div class="row g-3">
            <% if (user.role === 'admin') { %>
              <div class="col-md-6">
                <label class="form-label">Faculty</label>
                <select name="facultyId" class="form-select" required>
                  <% facultyList.forEach(f => { %>
                    <option value="<%= f._id %>" <%= String(f._id) === String(wl.faculty) ? 'selected' : '' %>>
                      <%= f.name %> — <%= f.department %>
                    </option>
                  <% }) %>
                </select>
              </div>
            <% } else { %>
              <div class="col-md-6">
                <label class="form-label">Faculty</label>
                <input class="form-control" value="<%= user.name %>" disabled />
              </div>
            <% } %>
            <div class="col-md-6">
              <label class="form-label">Department</label>
              <input name="department" class="form-control" value="<%= wl.department %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Course</label>
              <input name="course" class="form-control" value="<%= wl.course %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Workload Type</label>
              <select name="workloadType" class="form-select" required>
                <% workloadTypes.forEach(t => { %>
                  <option value="<%= t %>" <%= wl.workloadType === t ? 'selected' : '' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Hours</label>
              <input name="hours" type="number" min="0" step="0.5" class="form-control" value="<%= wl.hours %>" required />
            </div>
            <div class="col-md-4">
              <label class="form-label">Semester</label>
              <input name="semester" class="form-control" value="<%= wl.semester %>" required />
            </div>
            <div class="col-md-4">
              <label class="form-label">Academic Year</label>
              <input name="academicYear" class="form-control" value="<%= wl.academicYear %>" required />
            </div>
            <div class="col-12 d-flex gap-2">
              <button class="btn btn-dark" type="submit">Save Changes</button>
              <a class="btn btn-outline-dark" href="/workloads">Cancel</a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
