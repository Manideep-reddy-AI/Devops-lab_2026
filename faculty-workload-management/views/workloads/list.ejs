<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="content p-3 p-lg-4">
    <div class="d-flex flex-wrap align-items-end justify-content-between gap-2 mb-3">
      <div>
        <div class="text-muted small">Manage</div>
        <h1 class="h4 mb-0">Workloads</h1>
      </div>
      <a class="btn btn-dark" href="/workloads/new">Add Workload</a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <form class="row g-2 align-items-end" method="get" action="/workloads">
          <div class="col-12 col-md-6 col-lg-5">
            <label class="form-label">Search</label>
            <input name="q" class="form-control" value="<%= q %>" placeholder="Faculty, department, course, type, semester, year" />
          </div>
          <div class="col-6 col-md-3 col-lg-3">
            <label class="form-label">Sort</label>
            <select name="sort" class="form-select">
              <option value="createdAt" <%= sort === 'createdAt' ? 'selected' : '' %>>Newest</option>
              <option value="facultyName" <%= sort === 'facultyName' ? 'selected' : '' %>>Faculty</option>
              <option value="department" <%= sort === 'department' ? 'selected' : '' %>>Department</option>
              <option value="course" <%= sort === 'course' ? 'selected' : '' %>>Course</option>
              <option value="workloadType" <%= sort === 'workloadType' ? 'selected' : '' %>>Type</option>
              <option value="hours" <%= sort === 'hours' ? 'selected' : '' %>>Hours</option>
              <option value="semester" <%= sort === 'semester' ? 'selected' : '' %>>Semester</option>
              <option value="academicYear" <%= sort === 'academicYear' ? 'selected' : '' %>>Academic Year</option>
            </select>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <label class="form-label">Direction</label>
            <select name="dir" class="form-select">
              <option value="desc" <%= dir === 'desc' ? 'selected' : '' %>>Desc</option>
              <option value="asc" <%= dir === 'asc' ? 'selected' : '' %>>Asc</option>
            </select>
          </div>
          <div class="col-12 col-lg-2 d-grid">
            <button class="btn btn-outline-dark" type="submit">Apply</button>
          </div>
        </form>
      </div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Faculty</th>
              <th>Department</th>
              <th>Course</th>
              <th>Type</th>
              <th class="text-end">Hours</th>
              <th>Semester</th>
              <th>Academic Year</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!workloads.length) { %>
              <tr>
                <td colspan="8" class="text-center text-muted py-4">No workload records found.</td>
              </tr>
            <% } %>
            <% workloads.forEach(w => { %>
              <tr>
                <td class="fw-semibold"><%= w.facultyName %></td>
                <td><%= w.department %></td>
                <td><%= w.course %></td>
                <td><span class="badge text-bg-secondary"><%= w.workloadType %></span></td>
                <td class="text-end"><%= w.hours %></td>
                <td><%= w.semester %></td>
                <td><%= w.academicYear %></td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-dark" href="/workloads/<%= w._id %>/edit">Edit</a>
                  <form action="/workloads/<%= w._id %>?_method=DELETE" method="post" class="d-inline" data-confirm="Delete this workload?">
                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
