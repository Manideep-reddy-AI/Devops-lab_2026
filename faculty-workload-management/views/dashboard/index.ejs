<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="app-shell">
  <%- include('../partials/sidebar') %>

  <main class="content p-3 p-lg-4">
    <div class="d-flex flex-wrap align-items-end justify-content-between gap-2 mb-3">
      <div>
        <div class="text-muted small">Overview</div>
        <h1 class="h4 mb-0">Dashboard</h1>
      </div>
      <div class="text-muted small">
        <% if (user.role === 'admin') { %>
          Admin view (all data)
        <% } else { %>
          Faculty view (your data)
        <% } %>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card metric-card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted small">Total Faculty</div>
            <div class="metric"><%= stats.facultyCount %></div>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card metric-card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted small">Total Courses</div>
            <div class="metric"><%= stats.courseCount %></div>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card metric-card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted small">Workload Assigned (hrs)</div>
            <div class="metric"><%= stats.assignedHours %></div>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <div class="card metric-card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted small">Pending Requests</div>
            <div class="metric"><%= stats.pendingCount %></div>
            <div class="small text-muted">Workloads with 0 hours</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <div class="fw-semibold">Workload by Department</div>
              <a class="btn btn-outline-dark btn-sm" href="/workloads">View workloads</a>
            </div>
            <canvas id="deptChart" height="130"></canvas>
          </div>
        </div>
      </div>
      <div class="col-12 col-xl-5">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="fw-semibold mb-2">Workload by Type</div>
            <canvas id="typeChart" height="130"></canvas>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
      const byDepartment = <%- JSON.stringify(chartData.byDepartment || []) %>;
      const byType = <%- JSON.stringify(chartData.byType || []) %>;

      const deptLabels = byDepartment.map(x => x._id || "Unknown");
      const deptValues = byDepartment.map(x => x.totalHours || 0);

      const typeLabels = byType.map(x => x._id || "Unknown");
      const typeValues = byType.map(x => x.totalHours || 0);

      const deptCtx = document.getElementById("deptChart");
      new Chart(deptCtx, {
        type: "bar",
        data: {
          labels: deptLabels,
          datasets: [{
            label: "Hours",
            data: deptValues,
            backgroundColor: "rgba(13, 110, 253, 0.35)",
            borderColor: "rgba(13, 110, 253, 0.9)",
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true } }
        }
      });

      const typeCtx = document.getElementById("typeChart");
      new Chart(typeCtx, {
        type: "doughnut",
        data: {
          labels: typeLabels,
          datasets: [{
            data: typeValues,
            backgroundColor: [
              "rgba(25, 135, 84, 0.75)",
              "rgba(13, 110, 253, 0.75)",
              "rgba(255, 193, 7, 0.75)",
              "rgba(108, 117, 125, 0.75)"
            ],
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { position: "bottom" } }
        }
      });
    </script>
  </main>
</div>

<%- include('../partials/footer') %>
