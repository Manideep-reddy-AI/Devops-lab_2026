<%- include('../partials/head', { title }) %>

<div class="auth-bg">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-10 col-lg-7">
        <div class="card shadow-lg border-0">
          <div class="card-body p-4 p-lg-5">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div>
                <div class="text-muted small">Get started</div>
                <h1 class="h4 mb-0">Register</h1>
              </div>
              <div class="brand-badge"><%= appName %></div>
            </div>

            <%- include('../partials/flash') %>

            <form action="/auth/register" method="post" class="mt-3">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Full Name</label>
                  <input name="name" class="form-control" autocomplete="name" required />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Department</label>
                  <input name="department" class="form-control" required />
                </div>
                <div class="col-md-8">
                  <label class="form-label">Email</label>
                  <input name="email" type="email" class="form-control" autocomplete="email" required />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Role</label>
                  <select name="role" class="form-select" required>
                    <% roleOptions.forEach(o => { %>
                      <option value="<%= o.value %>"><%= o.label %></option>
                    <% }) %>
                  </select>
                  <div class="form-text">
                    <% if (roleOptions.length === 1) { %>
                      Admin role is locked once an admin exists.
                    <% } else { %>
                      First account can be Admin.
                    <% } %>
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Password</label>
                  <input name="password" type="password" class="form-control" autocomplete="new-password" minlength="8" required />
                  <div class="form-text">Minimum 8 characters.</div>
                </div>
                <div class="col-12">
                  <button class="btn btn-dark w-100" type="submit">Create Account</button>
                </div>
              </div>
            </form>

            <div class="text-center mt-3">
              <span class="text-muted">Already have an account?</span>
              <a href="/auth/login">Login</a>
            </div>
          </div>
        </div>
        <div class="text-center text-white-50 small mt-3">Tip: create the Admin account first.</div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
