<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="content p-3 p-lg-4">
    <div class="d-flex align-items-end justify-content-between gap-2 mb-3">
      <div>
        <div class="text-muted small">Create</div>
        <h1 class="h4 mb-0">Add Workload</h1>
      </div>
      <a class="btn btn-outline-dark" href="/workloads">Back</a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <form action="/workloads" method="post">
          <div class="row g-3">
            <% if (user.role === 'admin') { %>
              <div class="col-md-6">
                <label class="form-label">Faculty</label>
                <select name="facultyId" class="form-select" required>
                  <option value="">Select faculty</option>
                  <% facultyList.forEach(f => { %>
                    <option value="<%= f._id %>"><%= f.name %> — <%= f.department %></option>
                  <% }) %>
                </select>
              </div>
            <% } else { %>
              <div class="col-md-6">
                <label class="form-label">Faculty</label>
                <input class="form-control" value="<%= user.name %>" disabled />
              </div>
            <% } %>
            <div class="col-md-6">
              <label class="form-label">Department</label>
              <input name="department" class="form-control" value="<%= user.department %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Course</label>
              <input name="course" class="form-control" placeholder="e.g., CS101" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Workload Type</label>
              <select name="workloadType" class="form-select" required>
                <% workloadTypes.forEach(t => { %>
                  <option value="<%= t %>"><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Hours</label>
              <input name="hours" type="number" min="0" step="0.5" class="form-control" value="0" required />
              <div class="form-text">Use 0 for “Pending”.</div>
            </div>
            <div class="col-md-4">
              <label class="form-label">Semester</label>
              <input name="semester" class="form-control" placeholder="e.g., Fall" required />
            </div>
            <div class="col-md-4">
              <label class="form-label">Academic Year</label>
              <input name="academicYear" class="form-control" placeholder="e.g., 2025-2026" required />
            </div>
            <div class="col-12 d-flex gap-2">
              <button class="btn btn-dark" type="submit">Save</button>
              <a class="btn btn-outline-dark" href="/workloads">Cancel</a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
