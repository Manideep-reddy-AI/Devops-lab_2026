<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-body">
      <%- include('../partials/flash') %>
      <div class="table-card">
        <div class="table-header">
          <h3><i class="fas fa-users"></i> User Management</h3>
        </div>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Phone</th>
                <th>Grievances</th>
                <th>Last Login</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((u, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td>
                  <div class="user-cell">
                    <div class="avatar-sm"><%= u.name.charAt(0).toUpperCase() %></div>
                    <%= u.name %>
                  </div>
                </td>
                <td><%= u.email %></td>
                <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
                <td><%= u.phone || 'N/A' %></td>
                <td><%= u.grievanceCount %></td>
                <td><%= u.lastLogin ? new Date(u.lastLogin).toLocaleDateString() : 'Never' %></td>
                <td><span class="badge <%= u.isActive ? 'badge-active' : 'badge-inactive' %>"><%= u.isActive ? 'Active' : 'Inactive' %></span></td>
                <td class="actions">
                  <a href="/users/<%= u._id %>/edit" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                  <form action="/users/<%= u._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this user?')">
                    <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
