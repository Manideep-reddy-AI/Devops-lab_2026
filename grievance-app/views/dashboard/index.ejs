<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/navbar') %>
    <div class="page-body">
      <%- include('../partials/flash') %>

      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card blue">
          <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
          <div class="stat-info">
            <h3><%= totalGrievances %></h3>
            <p>Total Grievances</p>
          </div>
        </div>
        <div class="stat-card orange">
          <div class="stat-icon"><i class="fas fa-clock"></i></div>
          <div class="stat-info">
            <h3><%= pending %></h3>
            <p>Pending</p>
          </div>
        </div>
        <div class="stat-card purple">
          <div class="stat-icon"><i class="fas fa-spinner"></i></div>
          <div class="stat-info">
            <h3><%= inProgress %></h3>
            <p>In Progress</p>
          </div>
        </div>
        <div class="stat-card green">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info">
            <h3><%= resolved %></h3>
            <p>Resolved</p>
          </div>
        </div>
        <% if (totalUsers !== null) { %>
        <div class="stat-card red">
          <div class="stat-icon"><i class="fas fa-users"></i></div>
          <div class="stat-info">
            <h3><%= totalUsers %></h3>
            <p>Total Users</p>
          </div>
        </div>
        <% } %>
      </div>

      <!-- Charts -->
      <div class="charts-grid">
        <div class="chart-card">
          <h3>Grievances Per Month</h3>
          <canvas id="barChart"></canvas>
        </div>
        <div class="chart-card">
          <h3>Grievances By Category</h3>
          <canvas id="pieChart"></canvas>
        </div>
      </div>

      <!-- Recent Grievances Table -->
      <div class="table-card">
        <div class="table-header">
          <h3>Recent Grievances</h3>
          <a href="/grievances" class="btn btn-sm btn-primary">View All</a>
        </div>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Ticket ID</th>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Submitted By</th>
                <th>Date</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (recentGrievances.length === 0) { %>
              <tr><td colspan="8" class="text-center">No grievances found.</td></tr>
              <% } %>
              <% recentGrievances.forEach(g => { %>
              <tr>
                <td><span class="ticket-id"><%= g.ticketId %></span></td>
                <td><%= g.title.substring(0, 30) %><%= g.title.length > 30 ? '...' : '' %></td>
                <td><%= g.category %></td>
                <td><span class="badge status-<%= g.status.replace(/\s/g,'-').toLowerCase() %>"><%= g.status %></span></td>
                <td><span class="badge priority-<%= g.priority.toLowerCase() %>"><%= g.priority %></span></td>
                <td><%= g.submittedBy ? g.submittedBy.name : 'N/A' %></td>
                <td><%= new Date(g.createdAt).toLocaleDateString() %></td>
                <td><a href="/grievances/<%= g._id %>" class="btn btn-sm btn-outline">View</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
  const months = <%- months %>;
  const monthlyCounts = <%- monthlyCounts %>;
  const categories = <%- categories %>;
  const categoryCounts = <%- categoryCounts %>;

  new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
      labels: months,
      datasets: [{ label: 'Grievances', data: monthlyCounts, backgroundColor: '#4f46e5', borderRadius: 6 }]
    },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
  });

  new Chart(document.getElementById('pieChart'), {
    type: 'doughnut',
    data: {
      labels: categories,
      datasets: [{ data: categoryCounts, backgroundColor: ['#4f46e5','#06b6d4','#f59e0b','#10b981','#ef4444','#8b5cf6','#ec4899','#6b7280'] }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
  });
</script>
<%- include('../partials/footer') %>
